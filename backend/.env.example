# ============================================================
# Kai Study Arena Backend — Environment Variables
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Database — Supabase PostgreSQL (Transaction Pooler)
# Format: postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require

# Direct connection for migrations (port 5432, NOT pooled)
# Format: postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Provider: 'xai' (Grok), 'groq', or 'openrouter'
AI_PROVIDER=xai

# xAI Grok API
XAI_API_KEY=your-xai-api-key
XAI_MODEL=grok-3-mini-fast

# Groq API (alternative)
# AI_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama3-70b-8192

# OpenRouter (alternative)
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Rate Limiting
QUIZ_RATE_LIMIT_PER_DAY=10

# Frontend URL (CORS — update with your Vercel domain)
FRONTEND_URL=http://localhost:3000
